# Google OAuth (required)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# The public URL of this app (used for the OAuth callback)
BASE_URL=https://your-app-domain.com

# Session secret (generate a random string)
SESSION_SECRET=your_random_session_secret

# Comma-separated list of Google email addresses allowed to access the app
# If left empty, any authenticated Google account is allowed
ALLOWED_EMAILS=user@example.com,user2@example.com

# HubSpot
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
HUBSPOT_APPS_TOKEN=your_hubspot_apps_token

# Google Apps Script
APPS_SCRIPT_URL=your_apps_script_url
APPS_SCRIPT_SECRET=bw-gen-2026

PORT=3000
